# ===== Dominio / esquema =====
FQDN=notes.rrintecai.co
SCHEME=https
WS_SCHEME=wss
APPFLOWY_BASE_URL=https://notes.rrintecai.co
APPFLOWY_WEBSOCKET_BASE_URL=wss://notes.rrintecai.co/ws/v2
APPFLOWY_WEB_URL=https://notes.rrintecai.co

# ===== Postgres =====
POSTGRES_HOST=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=__CHANGE_ME__
POSTGRES_PORT=5432
POSTGRES_DB=postgres

# ===== Redis =====
REDIS_HOST=redis
REDIS_PORT=6379

# ===== MinIO / S3 =====
MINIO_HOST=minio
MINIO_PORT=9000
AWS_ACCESS_KEY=__CHANGE_ME__
AWS_SECRET=__CHANGE_ME__
APPFLOWY_S3_USE_MINIO=true
APPFLOWY_S3_CREATE_BUCKET=true
APPFLOWY_S3_MINIO_URL=http://minio:9000
APPFLOWY_S3_ACCESS_KEY=__CHANGE_ME__
APPFLOWY_S3_SECRET_KEY=__CHANGE_ME__
APPFLOWY_S3_BUCKET=appflowy
APPFLOWY_S3_REGION=us-east-1
APPFLOWY_S3_PRESIGNED_URL_ENDPOINT=https://notes.rrintecai.co/minio-api

# ===== AppFlowy Cloud =====
APPFLOWY_GOTRUE_BASE_URL=http://gotrue:9999
APPFLOWY_DATABASE_URL=postgres://postgres:__CHANGE_ME__@postgres:5432/postgres
APPFLOWY_ACCESS_CONTROL=true
APPFLOWY_DATABASE_MAX_CONNECTIONS=40
APPFLOWY_REDIS_URI=redis://redis:6379
GOTRUE_DATABASE_URL=postgres://postgres:__CHANGE_ME__@postgres:5432/postgres?search_path=auth

# ===== GoTrue (auth) =====
GOTRUE_ADMIN_EMAIL=ing2oscar@gmail.com
GOTRUE_ADMIN_PASSWORD=__CHANGE_ME__
GOTRUE_JWT_SECRET=__CHANGE_ME__
GOTRUE_JWT_EXP=604800
API_EXTERNAL_URL=https://notes.rrintecai.co/gotrue
GOTRUE_MAILER_AUTOCONFIRM=true
GOTRUE_DISABLE_SIGNUP=true
GOTRUE_RATE_LIMIT_EMAIL_SENT=100
GOTRUE_MAILER_TEMPLATES_MAGIC_LINK=
GOTRUE_SMTP_HOST=
GOTRUE_SMTP_PORT=465
GOTRUE_SMTP_USER=
GOTRUE_SMTP_PASS=
GOTRUE_SMTP_ADMIN_EMAIL=ing2oscar@gmail.com
GOTRUE_EXTERNAL_GOOGLE_ENABLED=false
GOTRUE_EXTERNAL_GOOGLE_CLIENT_ID=
GOTRUE_EXTERNAL_GOOGLE_SECRET=
GOTRUE_EXTERNAL_GOOGLE_REDIRECT_URI=https://notes.rrintecai.co/gotrue/callback

# ===== AppFlowy Mailer (sin uso real por ahora; placeholders para arranque) =====
APPFLOWY_MAILER_SMTP_HOST=smtp.gmail.com
APPFLOWY_MAILER_SMTP_PORT=465
APPFLOWY_MAILER_SMTP_USERNAME=noreply@notes.rrintecai.co
APPFLOWY_MAILER_SMTP_EMAIL=noreply@notes.rrintecai.co
APPFLOWY_MAILER_SMTP_PASSWORD=changeme
APPFLOWY_MAILER_SMTP_TLS_KIND=wrapper

# ===== IA (OpenAI en la nube) =====
AI_ENABLED=true
AI_SERVER_HOST=ai
AI_SERVER_PORT=5001
AI_OPENAI_API_KEY=__CHANGE_ME__
AI_OPENAI_API_SUMMARY_MODEL=gpt-4.1-mini
DEFAULT_AI_MODEL=gpt-4.1-mini
DEFAULT_AI_COMPLETION_MODEL=gpt-4.1-mini

# ===== Worker =====
APPFLOWY_WORKER_REDIS_URL=redis://redis:6379
APPFLOWY_WORKER_DATABASE_URL=postgres://postgres:__CHANGE_ME__@postgres:5432/postgres
APPFLOWY_WORKER_DATABASE_NAME=postgres

# ===== Otros =====
ASSEMBLYAI_API_KEY=
RUST_LOG=info
